{"name": "edit_file", "arguments": {"display_description":"Создаем скрипт для запуска Zed и VSCodium","mode":"create","path":"/home/dkadmin/.config/rofi/apps.sh","text":"#!/bin/bash\n\n# Groovbox Style App Launcher for Rofi\n\n# Список приложений\napps=(\n    \"Zed:zed\"\n    \"VSCodium:vscodium\"\n    \"Terminal:alacritty\"\n    \"File Manager:thunar\"\n    \"Browser:firefox\"\n    \"Music Player:spotify\"\n    \"Video Player:vlc\"\n    \"Settings:gnome-control-center\"\n)\n\n# Функция для запуска приложения\nlaunch_app() {\n    local app_name=\"$1\"\n    local app_command=\"$2\"\n    \n    # Проверяем, установлено ли приложение\n    if command -v \"$app_command\" &> /dev/null; then\n        # Запускаем приложение\n        \"$app_command\" &\n        # Закрываем rofi\n        exit 0\n    else\n        # Показываем сообщение об ошибке\n        notify-send \"Groovbox\" \"Application '$app_name' is not installed!\"\n        exit 1\n    fi\n}\n\n# Генерируем список для rofi\ngenerate_list() {\n    for app in \"${apps[@]}\"; do\n        echo \"$app\"\n    done\n}\n\n# Основная логика\nif [[ $# -eq 0 ]]; then\n    # Показываем список приложений\n    generate_list | rofi -dmenu -i -p \"Groovbox Apps\" -config \"/home/dkadmin/.config/rofi/config.rasi\"\nelse\n    # Запускаем выбранное приложение\n    local selected_app=\"$1\"\n    local app_name=\"${selected_app%%:*}\"\n    local app_command=\"${selected_app#*:}\"\n    \n    launch_app \"$app_name\" \"$app_command\"\nfi"}}
